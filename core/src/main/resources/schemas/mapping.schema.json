{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codelry.com/schemas/mapping.schema.json",
  "title": "CDC Mapping Config",
  "type": "object",
  "required": ["mappings"],
  "additionalProperties": false,
  "properties": {
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "additionalProperties": false,
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "scope": { "type": "string" },
              "collection": { "type": "string" }
            }
          },
          "key": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "template": { "type": "string" }
            }
          },
          "document": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["source"],
                  "additionalProperties": false,
                  "properties": {
                    "source": { "type": "string" },
                    "target": { "type": "string" },
                    "type": {
                      "type": "string",
                      "enum": ["iso8601", "string", "number", "boolean", "epochMillis"]
                    }
                  }
                }
              },
              "omit": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "softDelete": { "type": "boolean" }
        }
      }
    }
  }
}
